# ----- Supabase -----
# Project URL and keys from your Supabase project settings (API keys).
NEXT_PUBLIC_SUPABASE_URL=
# Newer "publishable" key (sb_publishable_...). RLS-scoped; safe in the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (sb_secret_...) — SERVER ONLY. Bypasses RLS. Never expose it.
SUPABASE_SECRET_KEY=

# Set to "supabase" to read live data; defaults to the bundled demo source.
NEXT_PUBLIC_DATA_SOURCE=demo

# ----- Plaid -----
# Create a free account at https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
# one of: sandbox | development | production
PLAID_ENV=sandbox

# ----- App -----
# Public base URL, used for Plaid webhooks / OAuth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
