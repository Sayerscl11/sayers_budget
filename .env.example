# ----- Supabase -----
# Project URL and keys from your Supabase project settings (API).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Plaid -----
# Create a free account at https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
# one of: sandbox | development | production
PLAID_ENV=sandbox

# ----- App -----
# Public base URL, used for Plaid webhooks / OAuth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
